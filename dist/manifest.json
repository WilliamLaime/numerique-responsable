{
  "manifest_version": 3,
  "name": "Numérique Responsable",
  "version": "1.0.0",
  "description": "Audit d'accessibilité (RGAA) et d'écoconception (RGESN) de la page courante.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Numérique Responsable — ouvrir le panneau",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "tabs", "storage", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"]
}
